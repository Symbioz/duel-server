{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "node"
  },
  "include": ["app.config.ts", "server/**/*", "client/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "server/infrastructure/websocket/ControllerMessageTypes.ts",
    "server/infrastructure/gesture-recognition/spell-glyphs/**/*.ts"
  ]
}

