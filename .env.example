HOST=0.0.0.0
PORT=8787
CONTROLLER_ACCESS_KEY=change-me-with-a-long-random-secret
MAX_CONTROLLERS=5
WS_RATE_LIMIT_PER_SEC=120
WS_MAX_PAYLOAD_BYTES=4096
# Optional hardening when exposed behind HTTPS/WSS
# ALLOWED_ORIGINS=https://duel.example.com
# Optional alternate path to the loaded env file
# APP_CONFIG_PATH=.env

# --- Voice / Voxtral spell recognition ---
# Mistral API key (https://console.mistral.ai)
# MISTRAL_API_KEY=your-api-key-here
#
# Optional: override to use a local vLLM server instead of the cloud API
#   Run locally: pip install vllm && vllm serve mistralai/Voxtral-Mini-3B-2507 --port 8000
# VOXTRAL_BASE_URL=http://localhost:8000
#
# Optional: override the model name (default: mistralai/Voxtral-Mini-4B-Realtime-2602)
# VOXTRAL_MODEL=mistralai/Voxtral-Mini-4B-Realtime-2602
# Optional: fail-fast timeout in ms for voice transcription
# VOXTRAL_TIMEOUT_MS=1800
# Optional: keep audio payload small for low latency
# VOICE_MAX_AUDIO_BYTES=1048576
# Optional: pin vLLM image when your NVIDIA driver is older (Error 804)
# VLLM_IMAGE=vllm/vllm-openai:latest

